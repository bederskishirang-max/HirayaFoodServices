    <section style="margin-top:3.5rem">
        <h2 class="section-title">Food Packages</h2>

        <div class="grid grid-2">
            @foreach (var p in Model.FoodPackages)
            {
                <article class="card-light">
                    <div class="card-light-head">
                        <div class="badge-gold">@p.Name</div>
                        <div class="price-big-dark">
                            PHP @p.Price.ToString("N0")
                        </div>
                    </div>

                    <ul class="bullets-dark">
                        @foreach (var i in p.Includes)
                        {
                        <li>• @i</li>
                        }
                    </ul>
                </article>
            }
        </div>

        <img src="~/img/menu-food-package.jpg"
             alt="Food package overview"
             loading="lazy"
             class="banner-img" />
    </section>
</div>