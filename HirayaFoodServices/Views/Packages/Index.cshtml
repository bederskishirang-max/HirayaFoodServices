@model HirayaFoodServices.Controllers.PackagesViewModel
@{
    ViewData["Title"] = "Packages";
}

<div class="container section">
    <header class="section-head">
        <span class="kicker">PACKAGES</span>
        <h1 class="display-2">Lechon Belly & Food Packages</h1>
    </header>

    <section>
        <h2 class="section-title">Lechon Belly Package</h2>
        <div class="grid grid-3">
            @foreach (var p in Model.LechonBelly)
            {
                <article class="card-dark">
                    <div class="badge-gold">@p.Tier</div>
                    <div class="price-big">PHP @p.Price.ToString("N0")</div>
                    <ul class="bullets">
                        <li>• LECHON BELLY (@p.Kg)</li>
                        <li>• 6 Side Dishes (Fix)</li>
                        <li>• @p.Pax</li>
                    </ul>
                </article>
            }
        </div>
        <img src="~/img/menu-lechon-belly.jpg" alt="Lechon belly platter" loading="lazy" class="banner-img" />
    </section>

    @*<section style="margin-top:3.5rem">
