@{
    ViewData["Title"] = "Contact";
}

<div class="container section narrow">
    <span class="kicker">CONTACT</span>
    <h1 class="display-2">Place an Order</h1>
    <p class="muted">Reach us through any of the channels below. Orders should be placed at least 2 days in advance.</p>

    <div class="grid grid-2 contact-grid">
        <div class="card-light pad">
            <div class="kicker">MOBILE</div>
            <p class="contact-line">+63 9xx xxx xxxx</p>
        </div>
        <div class="card-light pad">
            <div class="kicker">EMAIL</div>
            <p class="contact-line">orders@hirayafoods.ph</p>
        </div>
        <div class="card-light pad span-2">
            <div class="kicker">FACEBOOK</div>
            <p class="contact-line">facebook.com/HirayaFoodServices</p>
        </div>
    </div>
</div>